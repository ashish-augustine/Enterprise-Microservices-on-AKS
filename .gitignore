# Local .terraform directories
**/.terraform/*
.terraform/
.terraform.*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (prevents secret leaks)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore tfplan files
*tfplan*
